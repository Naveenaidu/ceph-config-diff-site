        "osd.yaml.in": {
            "osd_scrub_chunk_min": {
                "fmt_desc": {
                    "before": "The minimum number of objects to scrub during single operation. Also serves as a minimal chunk size even after scrubbing is preempted by client operations and the effective chunk size is halved.",
                    "after": "The minimal number of object store chunks to scrub during single operation. Ceph blocks writes to single chunk during scrub."
                }
            },
            "osd_scrub_backoff_ratio": {
                "long_desc": {
                    "before": "Probability that a particular OSD tick instance will skip scrub scheduling. 66% means that approximately one of three ticks will cause scrub scheduling.",
                    "after": "This is the precentage of ticks that do NOT schedule scrubs, 66% means that 1 out of 3 ticks will schedule scrubs"
                }
            },
            "osd_scrub_auto_repair_num_errors": {
                "desc": {
                    "before": "Maximum number of damaged objects to automatically repair",
                    "after": "Maximum number of detected errors to automatically repair"
                },
                "fmt_desc": {
                    "before": "Scrub will not perform automatic repair if more than this many damaged objects are found.",
                    "after": "Auto repair will not occur if more than this many errors are found."
                }
            },
            "osd_scrub_max_interval": {
                "desc": {
                    "before": "Scrub each PG no less often than this interval",
                    "after": "Scrub each PG no less often than this interval. Note that this option must be set at ``global`` scope, or for both ``mgr`` and``osd``."
                },
                "fmt_desc": {
                    "before": "The maximum interval in seconds for scrubbing the Ceph OSD Daemon irrespective of cluster load.",
                    "after": "The maximum interval in seconds for scrubbing each PG."
                }
            },
            "osd_scrub_auto_repair": {
                "fmt_desc": {
                    "before": "Setting this to ``true`` will enable automatic PG repair when errors are found by scrubs or deep-scrubs.  However, if more than ``osd_scrub_auto_repair_num_errors`` damaged objects are found a repair is NOT performed.",
                    "after": "Setting this to ``true`` will enable automatic PG repair when errors are found by scrubs or deep-scrubs.  However, if more than ``osd_scrub_auto_repair_num_errors`` errors are found a repair is NOT performed."
                }
            },
            "osd_scrub_min_interval": {
                "desc": {
                    "before": "The desired interval between scrubs of a specific PG.",
                    "after": "The desired interval between scrubs of a specific PG. Note that this option must be set at ``global`` scope, or for both ``mgr`` and``osd``."
                },
                "fmt_desc": {
                    "before": "The desired interval in seconds between scrubs of a specific PG when the Ceph Storage Cluster load is low.",
                    "after": "The desired interval in seconds between scrubs of a specific PG."
                }
            },
            "osd_deep_scrub_interval": {
                "desc": {
                    "before": "Deep scrub each PG (i.e., verify data checksums) at least this often",
                    "after": "Deep scrub each PG (i.e., verify data checksums) at least this often. Note that this option must be set at ``global`` scope, or for both ``mgr`` and``osd``."
